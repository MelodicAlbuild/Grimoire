@page "/download-client"
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Download Client - EmulationManager</PageTitle>

<div class="download-page">
    <h2>Get the Desktop Client</h2>
    <p class="text-secondary">Download EmulationManager for your platform to start playing games directly.</p>

    <div class="download-cards">
        <div class="download-card @(detectedOs == "windows" ? "detected" : "")">
            <h4>Windows</h4>
            <p>Windows 10/11 (x64)</p>
            <a href="@GetDownloadUrl("win-x64")" class="btn btn-primary" target="_blank">
                Download for Windows
            </a>
            @if (detectedOs == "windows")
            {
                <span class="detected-badge">Detected</span>
            }
        </div>

        <div class="download-card @(detectedOs == "macos" ? "detected" : "")">
            <h4>macOS</h4>
            <p>macOS (Apple Silicon)</p>
            <a href="@GetDownloadUrl("osx-arm64")" class="btn btn-primary" target="_blank">
                Download for macOS
            </a>
            @if (detectedOs == "macos")
            {
                <span class="detected-badge">Detected</span>
            }
        </div>

        <div class="download-card @(detectedOs == "linux" ? "detected" : "")">
            <h4>Linux</h4>
            <p>Linux (x64)</p>
            <a href="@GetDownloadUrl("linux-x64")" class="btn btn-primary" target="_blank">
                Download for Linux
            </a>
            @if (detectedOs == "linux")
            {
                <span class="detected-badge">Detected</span>
            }
        </div>
    </div>

    <div class="download-instructions">
        <h4>How it works</h4>
        <ol>
            <li>Download and run the client for your platform</li>
            <li>The client registers itself as a handler for <code>emumgr://</code> links</li>
            <li>Browse games here on the web, click <strong>Play</strong></li>
            <li>The desktop client opens, downloads the emulator if needed, downloads the game, and launches it</li>
        </ol>
    </div>
</div>

@code {
    private string? detectedOs;
    private string githubRepo = "yourusername/EmulationManager"; // Configure this

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            detectedOs = await DetectOsAsync();
            StateHasChanged();
        }
    }

    private async Task<string> DetectOsAsync()
    {
        try
        {
            var userAgent = await JS.InvokeAsync<string>("eval", "navigator.userAgent");
            if (userAgent.Contains("Win", StringComparison.OrdinalIgnoreCase)) return "windows";
            if (userAgent.Contains("Mac", StringComparison.OrdinalIgnoreCase)) return "macos";
            if (userAgent.Contains("Linux", StringComparison.OrdinalIgnoreCase)) return "linux";
        }
        catch { }
        return "unknown";
    }

    private string GetDownloadUrl(string rid)
    {
        return $"https://github.com/{githubRepo}/releases/latest/download/EmulationManager-{rid}.zip";
    }
}
