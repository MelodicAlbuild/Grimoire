@page "/"
@inject IGameService GameService
@rendermode InteractiveServer

<PageTitle>EmulationManager</PageTitle>

<div class="home-hero">
    <h1>EmulationManager</h1>
    <p>Browse and play games from the library. Select a platform to get started.</p>
</div>

@if (platforms is not null)
{
    <div class="stats-grid">
        <div class="stat-card stat-total">
            <div class="stat-number">@totalGames</div>
            <div class="stat-label">Total Games</div>
        </div>
        @foreach (var p in platforms)
        {
            <a href="games?platform=@p.Type" class="stat-card">
                <div class="stat-number">@p.GameCount</div>
                <div class="stat-label">@p.DisplayName</div>
            </a>
        }
    </div>

    <div class="home-actions">
        <a href="games" class="btn btn-primary btn-lg">Browse Library</a>
        <a href="download-client" class="btn btn-outline btn-lg">Get Desktop Client</a>
    </div>
}

@code {
    private IReadOnlyList<PlatformInfoDto>? platforms;
    private int totalGames;

    protected override async Task OnInitializedAsync()
    {
        platforms = await GameService.GetPlatformStatsAsync();
        totalGames = await GameService.GetGameCountAsync();
    }
}
