<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Nav Button -->
    <Style Selector="Button.nav-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#9898a8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#22222e" />
        <Setter Property="Foreground" Value="#e8e8ef" />
    </Style>
    <Style Selector="Button.nav-btn.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#6c5ce7" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Accent Button -->
    <Style Selector="Button.accent-btn">
        <Setter Property="Background" Value="#6c5ce7" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.accent-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#7d6ff0" />
    </Style>

    <!-- Outline Button -->
    <Style Selector="Button.outline-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#6c5ce7" />
        <Setter Property="BorderBrush" Value="#6c5ce7" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.outline-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#6c5ce7" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Filter Button -->
    <Style Selector="Button.filter-btn">
        <Setter Property="Background" Value="#22222e" />
        <Setter Property="Foreground" Value="#9898a8" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderBrush" Value="#2a2a3a" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.filter-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2a2a3a" />
        <Setter Property="Foreground" Value="#e8e8ef" />
    </Style>

    <!-- Search Input -->
    <Style Selector="TextBox.search-input">
        <Setter Property="Background" Value="#22222e" />
        <Setter Property="Foreground" Value="#e8e8ef" />
        <Setter Property="BorderBrush" Value="#2a2a3a" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="TextBox.search-input:focus">
        <Setter Property="BorderBrush" Value="#6c5ce7" />
    </Style>

    <!-- Game Card Button -->
    <Style Selector="Button.game-card-btn">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.game-card-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
</Styles>
