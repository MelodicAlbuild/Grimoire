<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EmulationManager.Desktop.ViewModels"
        xmlns:views="using:EmulationManager.Desktop.Views"
        x:Class="EmulationManager.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f14">

    <Window.Styles>
        <StyleInclude Source="/Assets/Styles.axaml" />
    </Window.Styles>

    <Grid ColumnDefinitions="220,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1a1a24" BorderBrush="#2a2a3a" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Title -->
                <TextBlock DockPanel.Dock="Top" Text="EmulationManager"
                           FontSize="18" FontWeight="Bold" Foreground="#e8e8ef"
                           Margin="20,20,20,30" />

                <!-- Nav Items -->
                <StackPanel Spacing="4" Margin="8,0">
                    <Button Command="{Binding NavigateToLibraryCommand}"
                            Classes="nav-btn" Classes.active="{Binding SelectedNavIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                        Game Library
                    </Button>
                    <Button Command="{Binding NavigateToDownloadsCommand}"
                            Classes="nav-btn" Classes.active="{Binding SelectedNavIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=1}">
                        Downloads
                    </Button>
                    <Button Command="{Binding NavigateToSettingsCommand}"
                            Classes="nav-btn" Classes.active="{Binding SelectedNavIndex, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=2}">
                        Settings
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="24,20">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:GameLibraryViewModel">
                    <views:GameLibraryView />
                </DataTemplate>
                <DataTemplate DataType="vm:DownloadsViewModel">
                    <views:DownloadsView />
                </DataTemplate>
                <DataTemplate DataType="vm:SettingsViewModel">
                    <views:SettingsView />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>
</Window>
