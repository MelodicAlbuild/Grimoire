<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Grimoire.Desktop.ViewModels"
             x:Class="Grimoire.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <StackPanel Spacing="20" MaxWidth="600">
        <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="#e8e8ef" />

        <StackPanel Spacing="12">
            <StackPanel Spacing="4">
                <TextBlock Text="Server URL" Foreground="#9898a8" FontSize="13" />
                <TextBox Text="{Binding ServerUrl}" Classes="search-input" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Install Directory" Foreground="#9898a8" FontSize="13" />
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Browse..."
                            Command="{Binding BrowseInstallDirectoryCommand}"
                            Classes="outline-btn" Margin="8,0,0,0" VerticalAlignment="Center" />
                    <TextBox Text="{Binding InstallDirectory}" Classes="search-input" />
                </DockPanel>
            </StackPanel>

            <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Classes="accent-btn" />

            <TextBlock Text="{Binding StatusMessage}" Foreground="#2ecc71"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
    </StackPanel>
</UserControl>
