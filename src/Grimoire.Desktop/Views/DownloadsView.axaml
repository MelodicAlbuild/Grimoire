<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Grimoire.Desktop.ViewModels"
             xmlns:svc="using:Grimoire.Desktop.Services"
             x:Class="Grimoire.Desktop.Views.DownloadsView"
             x:DataType="vm:DownloadsViewModel">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Downloads" FontSize="24" FontWeight="Bold"
                   Foreground="#e8e8ef" Margin="0,0,0,16" />

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Downloads}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="svc:DownloadItem">
                        <Border Background="#22222e" CornerRadius="6" Padding="16" Margin="0,0,0,8"
                                BorderBrush="#2a2a3a" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <Button Content="Cancel"
                                            Command="{Binding $parent[ItemsControl].DataContext.CancelDownloadCommand}"
                                            CommandParameter="{Binding}"
                                            Classes="outline-btn" Padding="8,4" FontSize="12" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#e8e8ef" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Foreground="#9898a8" FontSize="12">
                                            <Run Text="{Binding Status}" />
                                        </TextBlock>
                                        <TextBlock Foreground="#6c5ce7" FontSize="12">
                                            <Run Text="{Binding ProgressPercent, StringFormat={}{0:F1}%}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <!-- Progress bar -->
                                    <ProgressBar Minimum="0" Maximum="100"
                                                 Value="{Binding ProgressPercent}"
                                                 Height="4" Foreground="#6c5ce7" Background="#1a1a24" />
                                    <TextBlock Text="{Binding Error}" Foreground="#ff6b6b" FontSize="12"
                                               IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
