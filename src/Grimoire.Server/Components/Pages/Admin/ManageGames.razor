@page "/admin/games"
@inject IGameService GameService
@inject IGameAdminService AdminService
@rendermode InteractiveServer

<PageTitle>Manage Entries - Grimoire</PageTitle>

<AdminGuard>
    <div class="admin-header">
        <h2>Manage Entries</h2>
        <button class="btn btn-primary" @onclick="ShowAddForm">Add Entry</button>
    </div>

    @if (showForm)
    {
        <div class="admin-form">
            <h4>@(editingId.HasValue ? "Edit Entry" : "New Entry")</h4>
            <div class="form-group">
                <label>Title</label>
                <input class="form-control" @bind="formTitle" />
            </div>
            <div class="form-group">
                <label>Platform</label>
                <select class="form-control" @bind="formPlatform">
                    @foreach (var p in Enum.GetValues<PlatformType>())
                    {
                        <option value="@p">@p</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea class="form-control" @bind="formDescription" rows="3"></textarea>
            </div>
            <div class="form-group">
                <label>File Path (relative to storage)</label>
                <input class="form-control" @bind="formFilePath" />
            </div>
            <div class="form-group">
                <label>File Size (bytes)</label>
                <input class="form-control" type="number" @bind="formFileSize" />
            </div>
            <div class="form-group">
                <label>Cover Image Path (relative to covers storage, optional)</label>
                <input class="form-control" @bind="formCoverPath" placeholder="e.g. switch/zelda_botw.jpg" />
            </div>
            <div class="form-actions">
                <button class="btn btn-primary" @onclick="SaveGame">Save</button>
                <button class="btn btn-outline" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    }

    @if (games is null)
    {
        <p class="loading">Consulting the ledger...</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Title</th>
                    <th>Platform</th>
                    <th>DLC</th>
                    <th>Updates</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in games)
                {
                    <tr>
                        <td>@game.Id</td>
                        <td>@game.Title</td>
                        <td><PlatformBadge Platform="game.Platform" /></td>
                        <td>@(game.HasDlc ? "Yes" : "-")</td>
                        <td>@(game.HasUpdates ? "Yes" : "-")</td>
                        <td class="actions">
                            <a class="btn-sm btn-edit" href="/admin/games/@game.Id/content">DLC/Updates</a>
                            <button class="btn-sm btn-edit" @onclick="() => EditGame(game)">Edit</button>
                            <button class="btn-sm btn-delete" @onclick="() => DeleteGame(game.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</AdminGuard>

@code {
    private IReadOnlyList<GameListDto>? games;
    private bool showForm;
    private int? editingId;
    private string formTitle = "";
    private PlatformType formPlatform = PlatformType.NintendoSwitch;
    private string? formDescription;
    private string formFilePath = "";
    private long formFileSize;
    private string? formCoverPath;

    protected override async Task OnInitializedAsync() => await LoadGames();

    private async Task LoadGames() { games = await GameService.GetGamesAsync(); }

    private void ShowAddForm()
    {
        editingId = null; formTitle = ""; formPlatform = PlatformType.NintendoSwitch;
        formDescription = null; formFilePath = ""; formFileSize = 0; formCoverPath = null; showForm = true;
    }

    private void EditGame(GameListDto game)
    {
        editingId = game.Id; formTitle = game.Title; formPlatform = game.Platform;
        formDescription = null; formFilePath = ""; formFileSize = 0; formCoverPath = null; showForm = true;
    }

    private void CancelForm() => showForm = false;

    private async Task SaveGame()
    {
        var cover = string.IsNullOrWhiteSpace(formCoverPath) ? null : formCoverPath;
        if (editingId.HasValue)
            await AdminService.UpdateGameAsync(editingId.Value, new GameUpdateDto(
                formTitle, formPlatform, formDescription, formFilePath, formFileSize, cover));
        else
            await AdminService.CreateGameAsync(new GameCreateDto(
                formTitle, formPlatform, formDescription, formFilePath, formFileSize, cover));
        showForm = false;
        await LoadGames();
    }

    private async Task DeleteGame(int id) { await AdminService.DeleteGameAsync(id); await LoadGames(); }
}
